# Firebase (required) — from Firebase Console → Project settings → Your apps
VITE_FIREBASE_API_KEY=your_api_key
VITE_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
# Still required for Firebase init; app does NOT use Firebase Storage on Spark plan
VITE_FIREBASE_STORAGE_BUCKET=your_project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id

# Payments: demo | stripe
VITE_PAYMENT_GATEWAY=demo

# Stripe (optional, future)
VITE_STRIPE_PUBLISHABLE_KEY=

# Seed script only (do not commit serviceAccountKey.json)
GOOGLE_APPLICATION_CREDENTIALS=./serviceAccountKey.json
FIREBASE_PROJECT_ID=your_project_id
